{
  "name": "tourmaker-core",
  "version": "0.2.2",
  "description": "Framework-agnostic engine, schema and positioning for TourMaker interactive product tours.",
  "license": "MIT",
  "author": "Carlos Moreira",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosmoreira09/tourmaker.git",
    "directory": "packages/core"
  },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.12"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
